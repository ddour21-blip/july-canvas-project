# Firebase 설정 (Firebase 콘솔 > 프로젝트 설정 > 일반 > 내 앱 > SDK 설정)
# 이 파일을 .env.local 로 복사한 뒤 값을 채우고 dev 서버를 재시작하세요.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firestore 경로 네임스페이스 (선택, 기본값: july-canvas-app)
NEXT_PUBLIC_APP_ID=july-canvas-app

# AI 초안 생성용 Anthropic 키 (서버 전용, 선택). 미설정 시 템플릿 폴백으로 동작.
# 절대 NEXT_PUBLIC_ 접두사를 붙이지 말 것 (클라이언트 노출 금지).
ANTHROPIC_API_KEY=

# Firebase Admin 서비스 계정 (서버 전용, S7-2B public 공유 서버 매개 읽기용).
# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 생성(JSON)에서 값 추출.
# 절대 NEXT_PUBLIC_ 접두사 금지(클라이언트 노출 금지). 실제 키 값은 커밋 금지.
# FIREBASE_PRIVATE_KEY 는 한 줄로 넣고 줄바꿈을 \n 으로 escape (코드에서 실제 줄바꿈으로 복원).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# 비로그인 public review 스팸 방지 (S7-2F, 서버 전용).
# 레이트리밋 클라이언트 해시용 secret. 미설정 시 개발용 폴백 사용 → 운영에선 반드시 설정. raw IP는 저장 안 함.
PUBLIC_REVIEW_HASH_SECRET=
# CAPTCHA(현재 Cloudflare Turnstile 기준). 활성화 시 '1' 또는 'true'. 미설정/기타=비활성(로컬 기본).
PUBLIC_REVIEW_CAPTCHA_ENABLED=
PUBLIC_REVIEW_CAPTCHA_SECRET_KEY=
# CAPTCHA 위젯 site key (클라이언트 노출). 설정 시 public viewer에 보안 확인 영역 노출.
NEXT_PUBLIC_PUBLIC_REVIEW_CAPTCHA_SITE_KEY=
