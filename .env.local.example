# Firebase 설정 (Firebase 콘솔 > 프로젝트 설정 > 일반 > 내 앱 > SDK 설정)
# 이 파일을 .env.local 로 복사한 뒤 값을 채우고 dev 서버를 재시작하세요.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firestore 경로 네임스페이스 (선택, 기본값: july-canvas-app)
NEXT_PUBLIC_APP_ID=july-canvas-app

# (AI 키 예시 제거) July Canvas 로컬 AI 정책은 API 키 대신 `claude -p` 구독 인증을 사용합니다.
# AI 실행 분기는 아래 AI_PROVIDER / NEXT_PUBLIC_AI_ENABLED 로만 제어합니다.

# Firebase Admin 서비스 계정 (서버 전용, S7-2B public 공유 서버 매개 읽기용).
# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 생성(JSON)에서 값 추출.
# 절대 NEXT_PUBLIC_ 접두사 금지(클라이언트 노출 금지). 실제 키 값은 커밋 금지.
# FIREBASE_PRIVATE_KEY 는 한 줄로 넣고 줄바꿈을 \n 으로 escape (코드에서 실제 줄바꿈으로 복원).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# 비로그인 public review 스팸 방지 (S7-2F / S7-2G).
# [서버 전용] 레이트리밋 클라이언트 해시(IP+UA HMAC)용 secret. 미설정 시 개발용 폴백 → 운영에선 반드시 설정. raw IP는 저장 안 함.
PUBLIC_REVIEW_HASH_SECRET=
# [서버 전용] CAPTCHA 활성화 스위치(Cloudflare Turnstile). '1' 또는 'true' = 활성. 미설정/기타 = 비활성(로컬 기본).
PUBLIC_REVIEW_CAPTCHA_ENABLED=
# [서버 전용] Turnstile 비밀키(siteverify). 절대 NEXT_PUBLIC_ 금지. (로컬 테스트용 always-pass secret: 1x0000000000000000000000000000000AA)
PUBLIC_REVIEW_CAPTCHA_SECRET_KEY=
# [public/클라 노출] Turnstile 위젯 site key. 설정 시 public viewer에 보안 확인 위젯 노출. (테스트용 always-pass site key: 1x00000000000000000000AA)
NEXT_PUBLIC_PUBLIC_REVIEW_CAPTCHA_SITE_KEY=

# [public/클라 노출] 관리자 전용 도구 노출 스위치. '1' 일 때만 홈 더보기 메뉴에 '데이터 백업/복원'이 보임. 미설정 = 숨김(기본).
NEXT_PUBLIC_ADMIN_TOOLS=

# AI 실행 provider (서버 전용). 'disabled' | 'local-cli' | 'api'. 미설정 = disabled(안전 기본).
#   Vercel(배포): disabled  /  로컬: local-cli (추후 `claude -p` 구독 인증 사용, ANTHROPIC_API_KEY 미사용)
AI_PROVIDER=
# [public/클라 노출] AI 실행 버튼 노출 스위치. 'true' 일 때만 활성. Vercel=false, 로컬=true.
NEXT_PUBLIC_AI_ENABLED=
